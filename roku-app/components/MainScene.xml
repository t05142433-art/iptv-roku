<?xml version="1.0" encoding="utf-8" ?>
<component name="MainScene" extends="Scene">
  <children>
    <!-- Fundo Profissional -->
    <Poster id="bgImage" width="1920" height="1080" uri="https://picsum.photos/seed/iptv/1920/1080?blur=5" opacity="0.4" />
    <Rectangle id="backgroundOverlay" width="1920" height="1080" color="0x000000" opacity="0.7" />
    
    <!-- Logo 3D Ultra Estilizada -->
    <Group id="logoGroup" translation="[960, 250]">
        <!-- Camadas de profundidade para efeito 3D -->
        <Label text="THAYSON" font="font:LargeBoldSystemFont" color="0x000000" translation="[-142, 8]" opacity="0.6" />
        <Label text="THAYSON" font="font:LargeBoldSystemFont" color="0x33001a" translation="[-146, 4]" />
        <Label id="logoThayson" text="THAYSON" font="font:LargeBoldSystemFont" color="0xff007f" translation="[-150, 0]" />
        
        <Label text="&amp;" font="font:MediumBoldSystemFont" color="0xffffff" translation="[0, 60]" />
        
        <Label text="THAYLA" font="font:LargeBoldSystemFont" color="0x000000" translation="[-112, 108]" opacity="0.6" />
        <Label text="THAYLA" font="font:LargeBoldSystemFont" color="0x001a33" translation="[-116, 104]" />
        <Label id="logoThayla" text="THAYLA" font="font:LargeBoldSystemFont" color="0x007fff" translation="[-120, 100]" />
    </Group>

    <!-- Formulário de Login com Teclado -->
    <Group id="loginForm" translation="[460, 450]" visible="false">
        <Group id="inputArea" translation="[0, 0]">
            <Label text="USUÁRIO" translation="[0, 0]" font="font:SmallBoldSystemFont" color="0xff007f" />
            <Rectangle id="rectUser" width="400" height="60" color="0x222222" translation="[0, 40]" focusable="true" />
            <Label id="valUser" text="" translation="[15, 50]" font="font:SmallSystemFont" color="0xffffff" />

            <Label text="SENHA" translation="[0, 130]" font="font:SmallBoldSystemFont" color="0xff007f" />
            <Rectangle id="rectPass" width="400" height="60" color="0x222222" translation="[0, 170]" focusable="true" />
            <Label id="valPass" text="" translation="[15, 180]" font="font:SmallSystemFont" color="0xffffff" />

            <Label text="HOST (URL)" translation="[0, 260]" font="font:SmallBoldSystemFont" color="0x007fff" />
            <Rectangle id="rectHost" width="400" height="60" color="0x222222" translation="[0, 300]" focusable="true" />
            <Label id="valHost" text="" translation="[15, 310]" font="font:SmallSystemFont" color="0xffffff" />
            
            <Group id="buttonGroup" translation="[0, 420]">
                <Rectangle id="btnCancel" width="190" height="70" color="0x444444" translation="[0, 0]" focusable="true">
                    <Label text="CANCELAR" translation="[45, 20]" font="font:SmallBoldSystemFont" />
                </Rectangle>
                <Rectangle id="btnContinue" width="190" height="70" color="0xff007f" translation="[210, 0]" focusable="true">
                    <Label text="ENTRAR" translation="[60, 20]" font="font:SmallBoldSystemFont" />
                </Rectangle>
            </Group>
        </Group>

        <!-- Teclado Nativo Roku -->
        <Keyboard id="keyboard" translation="[500, 0]" visible="false" />
    </Group>

    <!-- Dashboard de Canais -->
    <Group id="dashboard" visible="false">
        <Rectangle width="1920" height="100" color="0x111111" />
        <Label text="THAYSON &amp; THAYLA IPTV - CANAIS" translation="[50, 30]" font="font:MediumBoldSystemFont" color="0xff007f" />
        
        <LabelList id="categoryList" translation="[50, 150]" itemSize="[400, 60]" />
        <LabelList id="streamList" translation="[500, 150]" itemSize="[1300, 60]" />
    </Group>

    <!-- Loading -->
    <Group id="loadingGroup" translation="[960, 850]">
        <Rectangle width="600" height="6" color="0x333333" translation="[-300, 0]" />
        <Rectangle id="loadingBar" width="0" height="6" color="0xff007f" translation="[-300, 0]" />
    </Group>

    <Video id="videoPlayer" width="1920" height="1080" visible="false" />
  </children>

  <script type="text/brightscript" uri="pkg:/components/MainScene.brs" />
</component>
